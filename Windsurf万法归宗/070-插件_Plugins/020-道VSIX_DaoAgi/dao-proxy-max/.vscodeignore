# dao-omni · .vscodeignore
# ═══════════════════════════════════════════════════════════════
# 排出 vsix 之物 · 守"无感"+"不抢道"
# ═══════════════════════════════════════════════════════════════

# 构建脚本本身 (主公手编, 不需打入 vsix)
_build_vsix.ps1
_build_vsix.cmd

# v1.0.6 · webview dev preview (本地仿真 · 不入 vsix)
webview/_preview.html
# v1.0.7 · webview live preview (跨主机闭环验 · 不入 vsix)
webview/_preview_live.html

# tests
tests/**

# git / node
.git/**
.gitignore
.gitattributes
node_modules/**
**/node_modules/**

# 真凭据 (永不入 vsix · 守 BYOK)
**/配置.json
**/config.json
**/配置.json.bak*
**/config.json.bak*
**/*.apikey
**/*.secret
# ★ 外接api路由配置 (朴散则为器 · 必入 vsix · 路由表非凭据)
!vendor/外接api/core/配置.json

# 日志 / 历史
**/*.log
**/*.err
**/*.bak
**/*.tmp
**/_*.out
**/_*.txt

# negate · 反代核运行时件 (源派 dao-proxy-min · 必入 vsix)
!vendor/bundled-origin/_v103_extras.js
!vendor/bundled-origin/_dao_81.txt
!vendor/bundled-origin/_custom_sp_templates.json
!vendor/bundled-origin/_sp_candidates.json
!vendor/bundled-origin/_lastinject.json
**/_logs/**
**/_archive/**
**/_history/**
**/_sample/**

# 编辑器 / 系统
.vscode/**
.idea/**
.DS_Store
Thumbs.db
desktop.ini

# 真药 R: 排出可能的字节级 SP dump
**/sp_dump_*.bin
**/rpc_*.bin
**/_rpc_*.bin

# vsce 自己生成 (避免循环打包)
*.vsix
dist/**

# 老朽残骸 (本工程无 · 防 future)
**/*.王弼版.bak
**/*.诗.bak
