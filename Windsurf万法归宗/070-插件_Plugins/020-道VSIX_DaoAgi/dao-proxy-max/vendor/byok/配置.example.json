{
  "_道": "外接api · 配置极简版 · 一键开通会自动填这里 · 14 家 provider 全字段见 配置.full.example.json",
  "_本源": "settings.json:codeium.apiServerUrl=:8878 → 010反代 → 070桥 → 070网关 :11435 → 上游",
  "_用法": "复制为 配置.json · 或直接跑 →一键开通.cmd 自动填",

  "gateway": {
    "host": "127.0.0.1",
    "port": 11435,
    "logLevel": "info"
  },

  "providers": {
    "github": {
      "_注": "GitHub Models 免费 · 取 PAT: https://github.com/settings/tokens (fine-grained · 仅勾 Models)",
      "enabled": false,
      "driver": "openai",
      "baseUrl": "https://models.github.ai/inference",
      "apiKey": "",
      "label": "GitHub Models",
      "models": [
        "openai/gpt-4o-mini",
        "openai/gpt-4.1-mini",
        "openai/gpt-4.1",
        "deepseek/deepseek-v3-0324",
        "meta/llama-3.3-70b-instruct"
      ]
    },
    "ollama": {
      "_注": "本地 · 装 Ollama 后改 enabled:true · 零网络 · auto = 自动列已下载模型",
      "enabled": false,
      "baseUrl": "http://127.0.0.1:11434",
      "models": ["auto"]
    }
  },

  "cascadeInjection": {
    "_注": "用户唯一开关 · enabled=true 时 070 桥把 injectModels 注入 Cascade 模型选择器",
    "_后手": "010-反代_Proxy 启动 · settings.json:codeium.apiServerUrl=http://127.0.0.1:8878",
    "_一键": "→一键开通.cmd 自动办妥后手",
    "enabled": false,
    "injectModels": [
      {
        "provider": "github",
        "model": "openai/gpt-4.1-mini",
        "label": "GPT-4.1 mini (免费 · GitHub)",
        "supportsImages": false,
        "supportsToolCalls": true,
        "maxTokens": 128000
      }
    ]
  },

  "officialByokOverrides": {
    "_道": "dao-proxy-max v1.0.0 · 官方 4 BYOK 透明劫 · 反者道之动",
    "_用": "Cascade 选择器仍显官方 Claude Opus/Sonnet 4 BYOK · 选中后底层无感折至 070 网关",
    "_启": "enabled=true 即生效 · map 中单条 enabled=false 可停某槽",
    "enabled": false,
    "map": {
      "MODEL_CLAUDE_4_OPUS_BYOK": {
        "_label": "Claude Opus 4 BYOK",
        "enabled": true,
        "provider": "github",
        "model": "openai/gpt-4.1",
        "supportsToolCalls": true,
        "maxTokens": 200000
      },
      "MODEL_CLAUDE_4_OPUS_THINKING_BYOK": {
        "_label": "Claude Opus 4 Thinking BYOK",
        "enabled": true,
        "provider": "deepseek",
        "model": "deepseek-reasoner",
        "supportsToolCalls": true,
        "supportsThinking": true,
        "maxTokens": 65536
      },
      "MODEL_CLAUDE_4_SONNET_BYOK": {
        "_label": "Claude Sonnet 4 BYOK",
        "enabled": true,
        "provider": "deepseek",
        "model": "deepseek-chat",
        "supportsToolCalls": true,
        "maxTokens": 65536
      },
      "MODEL_CLAUDE_4_SONNET_THINKING_BYOK": {
        "_label": "Claude Sonnet 4 Thinking BYOK",
        "enabled": true,
        "provider": "deepseek",
        "model": "deepseek-reasoner",
        "supportsToolCalls": true,
        "supportsThinking": true,
        "maxTokens": 65536
      }
    }
  }
}
