# 印 123 续 · 道生二 · 本地 client SDK 之 .env (示例)
# 用: 复此件为 .env.local · 自填活态 · 主公 source 之即可
#
# 道:
#   - 阴 (此 .env) · 主公本地态 · 0 daemon · 不入 git
#   - 阳 (VM 端) · 真本源 · 100% 同步态在 vm_pool.json
#
# 一字便填:
#   .\一笔便活.ps1 emit-env   # 自 vm_pool 之 alive 件 + auth 自动填此件

# ───────────────────────────────────────────
# 一 · VM 之 URL (主公一字 spawn 后自取)
# ───────────────────────────────────────────

# 主公 VM 之公网 URL · 形: https://user:xxx@omni-router-app-tunnel-XXX.devinapps.com
# (无须含 :port · 因 omni-router 之 8080 是默 ingress · 端口分流走 /port/<N>/ 路径)
DAO_VM_URL=https://user:xxx@omni-router-app-tunnel-XXX.devinapps.com

# ───────────────────────────────────────────
# 二 · auth 三法 · client 加 X-Dao-Auth 头 (代码 L2273-2276 · 全 4 法)
# ───────────────────────────────────────────
# auth 值 = VM 端 .dao_auth_token / .dao_meta_auth_token 之 32 hex (主公无须自造)
# (一笔便活.ps1 emit-env 自填此件)
#
# client 调用时 4 法任选一 (全被 dao_proxy/meta_router 认):
#   1. 头 X-Dao-Auth: <token>          ★ 推 (cloudfront tunnel 兼容)
#   2. 头 Authorization: Bearer <token>  ⚠ cloudfront tunnel 上可被脱带
#   3. 头 X-Api-Key: <token>           · OpenAI SDK 默之
#   4. URL ?key=<token>                · curl 友好

# auth1 · dao_proxy (:7780) · 单层反代 · 16 模 (Devin BYOK)
DAO_AUTH=

# auth2 · meta_router (:8081) · 双层反代 + fallback · 共 51 模 (dao 16 + github 35)
DAO_META_AUTH=

# 多账号轮转 (主公选用 token 池中之某号 · client 加头 X-Dao-Account: <name>)
# 不传则 dao_proxy 自动轮 (印 87 之多账号并行)
# DAO_ACCOUNT=

# ───────────────────────────────────────────
# 三 · client SDK 端点 (主公任选 · 三协议归一)
# ───────────────────────────────────────────

# OpenAI 协议 (推 · 三 SDK 通 · ChatGPT/Claude/Gemini 客端兼容)
OPENAI_BASE_URL=${DAO_VM_URL}/port/8081/v1
OPENAI_API_KEY=placeholder

# Anthropic 协议
ANTHROPIC_BASE_URL=${DAO_VM_URL}/port/8081/anthropic
ANTHROPIC_API_KEY=placeholder

# Gemini 协议
GEMINI_BASE_URL=${DAO_VM_URL}/port/8081/gemini

# Ollama 协议 (本地兼容 client)
OLLAMA_HOST=${DAO_VM_URL}/port/8081/ollama

# ───────────────────────────────────────────
# 四 · SP 七态参考 (实非 client ENV · 仅参考 · 切之走 HTTP)
# ───────────────────────────────────────────

# SP 模式: bypass | override | prepend | append | dao | custom | usernote
# - bypass   · 不动 client SP · 全透传
# - override · 全覆 client SP · 用 daemonSp
# - prepend  · 拼前 client SP · 用 daemonSp + client SP
# - append   · 拼后 client SP · 用 client SP + daemonSp
# - dao      · 道蕴 SP (帛书风 · 印 122 默)
# - custom   · 主公自定 SP (VM 端 SP_CUSTOM ENV)
# - usernote · 注 SP 至最后 user message 之前 (印 122 立 · Cognition 官认 SP §3.17 槽)
# ⚠ SP 切实非 client ENV · 是 VM 端 SP_STRATEGY ENV + POST /v1/system/prompt 热换
# client 切之: curl -X POST -H "X-Dao-Auth: $DAO_AUTH" \
#               -d '{"strategy":"usernote"}' $DAO_VM_URL/port/7780/v1/system/prompt
#
# Playbook 触发: 加头 X-Dao-Playbook: <name> (~/.dao/playbooks.json 配)

# ───────────────────────────────────────────
# 五 · 真测一字 (主公复粘即测)
# ───────────────────────────────────────────

# curl 一字探活 (源 .env.local 后)
# curl -H "X-Dao-Auth: $DAO_META_AUTH" $DAO_VM_URL/port/8081/health

# curl chat 一字真测
# curl -H "X-Dao-Auth: $DAO_META_AUTH" -H "Content-Type: application/json" \
#      -d '{"model":"openai/gpt-4o-mini","messages":[{"role":"user","content":"道可道"}]}' \
#      $DAO_VM_URL/port/8081/v1/chat/completions

# Python OpenAI SDK 一字真用 (source .env.local 后)
# python3 -c "from openai import OpenAI; import os; c=OpenAI(base_url=os.environ['OPENAI_BASE_URL'], api_key='x', default_headers={'X-Dao-Auth': os.environ['DAO_META_AUTH']}); print(c.chat.completions.create(model='openai/gpt-4o-mini', messages=[{'role':'user','content':'道'}]).choices[0].message.content)"
